<?php

/**
 * Handles data posted to this endpoint by Stripe (aka "webhooks").
 * 
 * https://stripe.com/docs/webhooks/build
 */

#################################################################################################### --- INCLUDE DEPENDENCIES

use PHPMailer\PHPMailer\PHPMailer;
use PHPMailer\PHPMailer\Exception;

use \Dompdf\Dompdf;
use \Dompdf\Options;

require_once PATH_PRIVATE . 'PHPMailer/src/PHPMailer.php';
require_once PATH_PRIVATE . 'PHPMailer/src/Exception.php';

require_once PATH_PRIVATE . 'dompdf/autoload.inc.php';

require_once PATH_PRIVATE . 'stripe-php-7.67.0/init.php';

#################################################################################################### --- GET STRIPE PAYLOAD

$stripe = new \Stripe\StripeClient (STRIPE_KEY_PHP);

$payload     = @file_get_contents('php://input');

$sig_header  = $_SERVER['HTTP_STRIPE_SIGNATURE'];

// ----------

$app->post('/stripe-webhook', function(Request $request, Response $response) {

  $event = $request->getParsedBody();
  
  $stripe = $this->stripe;

  // Parse the message body (and check the signature if possible)
  
  $webhookSecret = getenv(STRIPE_WEBHOOK_SECRET);
  
  if ($webhookSecret) {
  
    try {
    
      $event = $stripe->webhooks->constructEvent(
      
        $payload,
        
        $sig_header,
        
        $webhookSecret
      );

    } catch (Exception $e) {
    
      return $response->withJson([ 'error' => $e->getMessage() ])->withStatus(403);
      
      // Invalid payload
  
      error_log ("INVALID PAYLOAD\n\n");
      error_log ($e . "\n\n");
      
      http_response_code (403);
      exit;
    }
    
  } else {
  
    $event = $request->getParsedBody();
  }
  
  $type = $event['type'];
  
  $object = $event['data']['object'];
}

